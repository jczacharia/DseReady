library 'pipeline'

pipeline {
    agent any
    options {
        timeout(time: 2, unit: 'HOURS')
        disableConcurrentBuilds()
    }
    environment {
        MNEMONIC      = 'DSE'
        MANIFEST_FILE = 'helm.yaml'
        manifestFile  = 'helm.yaml'
        CR_NUMBER     = 'CHG0000000'
    }
    stages {
        stage('Initialization') {
            steps {
                script {
                    def buildNum = env.BUILD_NUMBER as int
                    if (buildNum > 1) milestone(buildNum - 1)
                    milestone(buildNum)
                }
                initialization()
            }
        }
        stage('Deploy') {
            when {
                anyOf {
                    branch pattern: 'stage-*'
                    branch pattern: 'release-*'
                }
            }
            steps {
                deploy(
                    ocp: true,
                    manifestFile: env.MANIFEST_FILE,
                    profile: env.BRANCH_NAME,
                    crNumber: env.CR_NUMBER
                )
            }
        }
        stage('Promote') {
            when { branch pattern: 'promote-*' }
            steps {
                promote(
                    crNumber: env.CR_NUMBER,
                    promote: [
                        chartPath: 'charts/dse-deploy'
                    ]
                )
            }
        }
    }
    post {
        cleanup {
            generalCleanup()
        }
    }
}


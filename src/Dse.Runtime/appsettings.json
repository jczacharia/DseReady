{
    "AllowedHosts": "*",
    "Ping": {
        "MetadataAddress": "https://wfsso-apps.pnc.com/.well-known/openid-configuration"
    },
    "Ldap": {
        "GroupsAttribute": "memberOf",
        "Ad": {
            "Host": "pncbank.com",
            "SearchBase": "DC=pncbank,DC=com",
            "GroupsFilter": "(&(objectClass=user)(!(objectClass=computer))(sAMAccountName={0}))"
        },
        "Oud": {
            "Host": "mdsemp.pncint.net",
            "SearchBase": "o=pnc",
            "GroupsFilter": "(uid={0})"
        }
    },
    "Confluence": {
        "InboundBufferMaxSize": 48000,
        "OutboundBufferMaxSize": 1000
    }
}

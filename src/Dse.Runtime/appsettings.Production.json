{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.Hosting.Lifetime": "Information",
            "Microsoft.EntityFrameworkCore": "Warning",
            "System.Net.Http.HttpClient": "Warning",
            "Polly": "Warning"
        },
        "Console": {
            "FormatterName": "json",
            "FormatterOptions": {
                "SingleLine": true,
                "IncludeScopes": true,
                "TimestampFormat": "yyyy-MM-ddTHH:mm:ss.fffZ ",
                "UseUtcTimestamp": true,
                "JsonWriterOptions": {
                    "Indented": false
                }
            }
        }
    }
}
